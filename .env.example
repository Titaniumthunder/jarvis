# Jarvis environment variables
#
# Copy this file to `.env` (which is gitignored) and fill in your own keys.
# With ALL three API keys left blank, Jarvis falls back to local Ollama and
# runs fully offline. Cloud calls are a speed optimization, not a requirement.
#
# ─── API keys ─────────────────────────────────────────────────────────────────
#
# GROQ_API_KEY — Primary fast LLM (Groq cloud, free tier).
#   Used by brain.py, llm_tool.py, diagram_agent.py for low-latency replies.
#   Get one at: https://console.groq.com/keys
#
# GEMINI_API_KEY — Optional Google Gemini fallback.
#   Used by tools/gemini_tool.py. Free tier: 1500 req/day.
#   Get one at: https://aistudio.google.com/app/apikey
#
# BRAVE_API_KEY — Web search backend.
#   Used by tools/search_tool.py for Brave Search + AI summary.
#   Get one at: https://brave.com/search/api/
#
GROQ_API_KEY=
GEMINI_API_KEY=
BRAVE_API_KEY=
